# =============================================================================
# LOCAL / DEV — never committed
# These are machine-specific or contain secrets. They must not be shared.
# =============================================================================

# uv virtual environment — recreate with: uv sync
.venv/

# API keys and secrets — NEVER commit these
.env
.env.*
secrets.yaml
*_key.txt

# Python cache
__pycache__/
*.py[cod]
*.pyo
.python-version

# Test / coverage cache
.pytest_cache/
.coverage
htmlcov/
.tox/

# Editor and OS noise
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db


# =============================================================================
# RUNTIME OUTPUTS — local run artifacts, not source code
# The outputs/ directory is tracked (via .gitkeep) but its contents are not.
# Model files, logs, and reports are generated per run — do not commit them.
# =============================================================================

outputs/*
!outputs/.gitkeep

# Jupyter notebooks (exploratory, not part of the project)
*.ipynb
.ipynb_checkpoints/

# Serialised models and data
*.pkl
*.pickle
*.joblib
*.h5
*.parquet
*.csv

# Logs
*.log
logs/


# =============================================================================
# BUILD ARTEFACTS — generated by packaging tools
# =============================================================================

dist/
build/
*.egg-info/
*.egg
.eggs/
