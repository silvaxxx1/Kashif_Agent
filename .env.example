# Kashif — environment variables template
# Copy this file to .env and fill in your keys.
#
#   cp .env.example .env
#
# .env is gitignored — .env.example is committed as documentation.

# Default provider (Groq) — get a free key at https://console.groq.com
GROQ_API_KEY=gsk_...

# Secondary provider (Anthropic) — only needed if provider: anthropic in config.yaml
ANTHROPIC_API_KEY=sk-ant-...
